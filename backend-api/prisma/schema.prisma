datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

/// Status of a sales lead in the pipeline.
enum LeadStatus {
  New
  Engaged
  ProposalSent
  ClosedWon
  ClosedLost
}

/// Registered user for authentication.
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// A sales lead tracked in the system.
model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  status    LeadStatus @default(New)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("leads")
}
